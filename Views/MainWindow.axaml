<Window
    x:Class="OsuInstaFadeSkinGenerator.Views.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:OsuInstaFadeSkinGenerator.ViewModels"
    Title="osu! insta-fade skin generator"
    Width="600"
    Height="650"
    MinWidth="600"
    MinHeight="650"
    d:DesignHeight="650"
    d:DesignWidth="600"
    CanResize="True"
    PointerPressed="Window_PointerPressed"
    x:DataType="vm:MainWindowViewModel"
    mc:Ignorable="d">

    <Grid Margin="24,22,24,22" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,*,Auto,Auto">

        <StackPanel
            Grid.Row="0"
            Margin="0,0,0,18"
            Orientation="Horizontal"
            Spacing="12">
            <Rectangle
                Width="4"
                Height="38"
                VerticalAlignment="Center"
                Fill="{StaticResource OsuHeaderAccentBrush}"
                RadiusX="2"
                RadiusY="2" />
            <StackPanel VerticalAlignment="Center" Spacing="2">
                <TextBlock
                    Classes="hero-title"
                    Text="osu! insta-fade skin generator" />
                <TextBlock
                    Classes="subtle"
                    FontSize="11"
                    Text="Convert a skin folder to insta-fade hitcircles." />
            </StackPanel>
        </StackPanel>

        <StackPanel
            Grid.Row="1"
            Margin="0,0,0,12"
            Spacing="6">
            <TextBlock
                Classes="section-header"
                Text="SKIN FOLDER" />
            <Grid ColumnDefinitions="*,Auto">
                <TextBox
                    Grid.Column="0"
                    Margin="0,0,8,0"
                    IsEnabled="{Binding IsInputEnabled}"
                    LostFocus="SkinFolderTextBox_LostFocus"
                    Text="{Binding SkinFolderPath, UpdateSourceTrigger=PropertyChanged}"
                    ToolTip.Tip="Write or paste the path to the osu! skin folder. Clicking away or pressing Enter confirms and loads it."
                    Watermark="Select skin folder...">
                    <TextBox.KeyBindings>
                        <KeyBinding Command="{Binding ConfirmSkinFolderPathCommand}" Gesture="Enter" />
                    </TextBox.KeyBindings>
                </TextBox>
                <Button
                    Classes="primary"
                    Grid.Column="1"
                    Command="{Binding BrowseCommand}"
                    Content="Browse"
                    ToolTip.Tip="Open a folder picker and choose the skin folder you want to convert to insta-fade hitcircles." />
            </Grid>
        </StackPanel>

        <StackPanel
            Grid.Row="2"
            Margin="0,0,0,12"
            Spacing="6">
            <TextBlock
                Classes="section-header"
                Text="COMBO COLOUR" />
            <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,*">
                <TextBlock
                    Classes="subtle"
                    Grid.Column="0"
                    Margin="0,0,4,0"
                    VerticalAlignment="Center"
                    FontSize="12"
                    FontWeight="Bold"
                    Text="R" />
                <TextBox
                    Grid.Column="1"
                    Width="52"
                    Margin="0,0,8,0"
                    IsEnabled="{Binding IsInputEnabled}"
                    Text="{Binding ColourRText, UpdateSourceTrigger=PropertyChanged}"
                    ToolTip.Tip="Red channel draft for Combo1. Enter values from 0 to 255, then press Apply to confirm the RGB colour." />

                <TextBlock
                    Classes="subtle"
                    Grid.Column="2"
                    Margin="0,0,4,0"
                    VerticalAlignment="Center"
                    FontSize="12"
                    FontWeight="Bold"
                    Text="G" />
                <TextBox
                    Grid.Column="3"
                    Width="52"
                    Margin="0,0,8,0"
                    IsEnabled="{Binding IsInputEnabled}"
                    Text="{Binding ColourGText, UpdateSourceTrigger=PropertyChanged}"
                    ToolTip.Tip="Green channel draft for Combo1. Enter values from 0 to 255, then press Apply to confirm the RGB colour." />

                <TextBlock
                    Classes="subtle"
                    Grid.Column="4"
                    Margin="0,0,4,0"
                    VerticalAlignment="Center"
                    FontSize="12"
                    FontWeight="Bold"
                    Text="B" />
                <TextBox
                    Grid.Column="5"
                    Width="52"
                    Margin="0,0,8,0"
                    IsEnabled="{Binding IsInputEnabled}"
                    Text="{Binding ColourBText, UpdateSourceTrigger=PropertyChanged}"
                    ToolTip.Tip="Blue channel draft for Combo1. Enter values from 0 to 255, then press Apply to confirm the RGB colour." />

                <Button
                    Classes="primary"
                    Grid.Column="6"
                    Margin="4,0,0,0"
                    Command="{Binding ApplyRgbCommand}"
                    Content="Apply"
                    ToolTip.Tip="Apply the RGB draft to confirm the Combo1 colour and update the preview." />

                <Border
                    Classes="colour-preview"
                    Grid.Column="7"
                    Width="36"
                    Height="36"
                    Margin="12,0,0,0"
                    HorizontalAlignment="Left"
                    Background="{Binding ColourPreviewBrush}"
                    CornerRadius="8"
                    ToolTip.Tip="Preview of the currently applied Combo1 colour that will tint the generated hitcircle and approach circle." />
            </Grid>
        </StackPanel>

        <Grid
            Grid.Row="3"
            Margin="0,0,0,14"
            ColumnDefinitions="Auto,Auto,Auto">
            <TextBlock
                Classes="subtle"
                Grid.Column="0"
                Margin="0,0,8,0"
                VerticalAlignment="Center"
                FontSize="12"
                FontWeight="Bold"
                Text="HEX" />
            <TextBox
                Grid.Column="1"
                Width="110"
                Margin="0,0,8,0"
                IsEnabled="{Binding IsInputEnabled}"
                Text="{Binding ColourHex, UpdateSourceTrigger=PropertyChanged}"
                ToolTip.Tip="Alternative draft colour input in #RRGGBB format. Press Apply to confirm it and sync the RGB fields." />
            <Button
                Classes="primary"
                Grid.Column="2"
                Command="{Binding ApplyHexCommand}"
                Content="Apply"
                ToolTip.Tip="Apply the hex draft to confirm the Combo1 colour, sync the RGB boxes, and update the preview." />
        </Grid>

        <StackPanel
            Grid.Row="4"
            Margin="0,0,0,12"
            Spacing="6">
            <TextBlock
                Classes="section-header"
                Text="OPTIONS" />
            <StackPanel Spacing="4">
                <CheckBox
                    Content="Backup original files before modifying"
                    IsChecked="{Binding BackupFiles}"
                    IsEnabled="{Binding IsInputEnabled}"
                    ToolTip.Tip="Copy the current hitcircle, hitcircleoverlay, numbered circle assets, and skin.ini before overwriting them. Recommended because generation is destructive." />
                <CheckBox
                    Content="Process @2x (HD) variants"
                    IsChecked="{Binding ProcessHd}"
                    IsEnabled="{Binding IsInputEnabled}"
                    ToolTip.Tip="Generate the @2x.png high-definition variants as well. Use this if the skin includes HD assets, which osu! detects through the @2x suffix." />
                <CheckBox
                    Content="Triplestacked (brighter circles for HD/DT)"
                    IsChecked="{Binding EnableTripleStacking}"
                    IsEnabled="{Binding IsInputEnabled}"
                    ToolTip.Tip="Keep stacked hitcircle, and hitcircleoverlay instead of making them transparent to make the skin brighter." />
            </StackPanel>
        </StackPanel>

        <Border
            Classes="panel error-panel"
            Grid.Row="5"
            Margin="0,0,0,12"
            Padding="12,10"
            IsVisible="{Binding HasErrors}">
            <TextBlock
                Foreground="{StaticResource OsuErrorTextBrush}"
                FontSize="12"
                Text="{Binding ErrorText}"
                TextWrapping="Wrap" />
        </Border>

        <Border
            Classes="panel log-panel"
            Grid.Row="6"
            Margin="0,0,0,14"
            Padding="10">
            <Grid RowDefinitions="Auto,*">
                <Grid
                    Grid.Row="0"
                    Margin="0,0,0,8"
                    ColumnDefinitions="*,Auto">
                    <TextBlock
                        Classes="section-header"
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        Text="LOGS" />
                    <Button
                        Classes="log-copy-button"
                        Grid.Column="1"
                        Command="{Binding CopyLogsCommand}"
                        Content="Copy"
                        ToolTip.Tip="Copy the full log output so you can share it when asking for help." />
                </Grid>

                <TextBox
                    Classes="log-output"
                    Grid.Row="1"
                    AcceptsReturn="True"
                    IsReadOnly="True"
                    Text="{Binding LogText}"
                    TextWrapping="NoWrap" />
            </Grid>
        </Border>

        <Grid
            Grid.Row="7"
            Margin="0,0,0,14"
            ColumnDefinitions="*,Auto"
            VerticalAlignment="Center">
            <ProgressBar
                Grid.Column="0"
                Height="10"
                Margin="0,0,12,0"
                VerticalAlignment="Center"
                Maximum="100"
                Minimum="0"
                Value="{Binding ProgressValue}" />
            <TextBlock
                Classes="subtle"
                Grid.Column="1"
                MinWidth="42"
                VerticalAlignment="Center"
                FontSize="11"
                FontWeight="Bold"
                TextAlignment="Right"
                Text="{Binding ProgressValue, StringFormat={}{0:F0}%}" />
        </Grid>

        <Button
            Classes="primary"
            Grid.Row="8"
            Height="44"
            HorizontalAlignment="Stretch"
            HorizontalContentAlignment="Center"
            Command="{Binding GenerateCommand}"
            Content="Generate Insta-Fade"
            FontSize="14"
            FontWeight="Bold"
            ToolTip.Tip="Proceed with creating insta-fade files for the selected skin." />
    </Grid>
</Window>
