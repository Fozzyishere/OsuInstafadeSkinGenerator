<Window
    x:Class="OsuInstaFadeSkinGenerator.Views.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sections="using:OsuInstaFadeSkinGenerator.Views.Sections"
    xmlns:vm="using:OsuInstaFadeSkinGenerator.ViewModels"
    Title="osu! insta-fade skin generator"
    Width="600"
    Height="650"
    MinWidth="600"
    MinHeight="650"
    d:DesignHeight="650"
    d:DesignWidth="600"
    CanResize="True"
    PointerPressed="Window_PointerPressed"
    x:DataType="vm:MainWindowViewModel"
    mc:Ignorable="d">

    <Grid Margin="24,22,24,22" RowDefinitions="Auto,Auto,Auto,Auto,Auto,*,Auto">

        <StackPanel
            Grid.Row="0"
            Margin="0,0,0,18"
            Orientation="Horizontal"
            Spacing="12">
            <Rectangle
                Width="4"
                Height="38"
                VerticalAlignment="Center"
                Fill="{StaticResource OsuHeaderAccentBrush}"
                RadiusX="2"
                RadiusY="2" />
            <StackPanel VerticalAlignment="Center" Spacing="2">
                <TextBlock
                    Classes="hero-title"
                    Text="osu! insta-fade skin generator" />
                <TextBlock
                    Classes="subtle"
                    FontSize="11"
                    Text="convert any skin to insta-fade skins with some simple tweaks" />
            </StackPanel>
        </StackPanel>

        <sections:SkinFolderSectionView
            Grid.Row="1"
            Margin="0,0,0,12"
            DataContext="{Binding Folder}"
            IsEnabled="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).IsInputEnabled}" />

        <sections:ColourSectionView
            Grid.Row="2"
            Margin="0,0,0,14"
            DataContext="{Binding Colour}"
            IsEnabled="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).IsInputEnabled}" />

        <sections:OptionsSectionView
            Grid.Row="3"
            Margin="0,0,0,12"
            DataContext="{Binding Options}"
            IsEnabled="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).IsInputEnabled}" />

        <Border
            Classes="panel error-panel"
            Grid.Row="4"
            Margin="0,0,0,12"
            Padding="12,10"
            IsVisible="{Binding HasErrors}">
            <TextBlock
                Foreground="{StaticResource OsuErrorTextBrush}"
                FontSize="12"
                Text="{Binding ErrorText}"
                TextWrapping="Wrap" />
        </Border>

        <sections:LogSectionView
            Grid.Row="5"
            DataContext="{Binding Log}" />

        <Grid Grid.Row="6" Margin="0,10,0,0">
            <Button
                Classes="primary"
                Height="44"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center"
                Command="{Binding GenerateCommand}"
                Content="Generate Skin"
                FontSize="14"
                FontWeight="Bold"
                IsVisible="{Binding !IsGenerating}"
                ToolTip.Tip="Proceed with creating insta-fade files for the selected skin." />
            <Button
                Classes="primary"
                Height="44"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center"
                Command="{Binding CancelCommand}"
                Content="{Binding CancelButtonText}"
                FontSize="14"
                FontWeight="Bold"
                IsVisible="{Binding IsGenerating}"
                ToolTip.Tip="Cancel generation and restore the selected skin to its original state." />
        </Grid>
    </Grid>
</Window>
